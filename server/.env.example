PORT=8787
CORS_ORIGIN=*

# CoPaw endpoint（按你的环境修改）
COPAW_MESSAGE_URL=http://localhost:8088/api/agent/process
COPAW_API_MODE=agent_process
# 可选：CoPaw API 根路径（不填时会尝试从 COPAW_MESSAGE_URL 推导）
# 例如：http://localhost:8088/api
COPAW_API_BASE_URL=
# 可选：显式指定 chat 列表接口；不填时默认 ${COPAW_API_BASE_URL}/chats
COPAW_CHATS_URL=
# 可选：显式指定停止任务接口；不填时默认 ${COPAW_API_BASE_URL}/console/chat/stop
COPAW_STOP_URL=
# 可选：停止接口的 chat_id 参数名
COPAW_STOP_CHAT_ID_PARAM=chat_id
# 可选：停止任务超时（毫秒），默认回退到 COPAW_TIMEOUT_MS
COPAW_STOP_TIMEOUT_MS=30000
# 可选：按 session_id 查找 chat_id 的重试次数/间隔（毫秒）
COPAW_STOP_LOOKUP_RETRIES=3
COPAW_STOP_LOOKUP_RETRY_DELAY_MS=250
# 可选：前端模型切换列表（本质映射为 X-Agent-Id），格式：id:label,id2:label2
# 例如：reasoner:DeepSeek Reasoner,qa:Knowledge QA
COPAW_MODEL_OPTIONS=reasoner:DeepSeek Reasoner,chat:DeepSeek Chat
# 可选：默认模型 id，不配置时默认使用上面列表第一个
COPAW_DEFAULT_MODEL=reasoner
# 可选：智能体切换列表，格式同上；不配时回退到 COPAW_MODEL_OPTIONS
COPAW_AGENT_OPTIONS=default:默认智能体,irSSp7:页面控制专家
# 可选：默认智能体 id，不配时回退到 COPAW_DEFAULT_MODEL
COPAW_DEFAULT_AGENT=irSSp7
COPAW_API_KEY=
COPAW_API_KEY_HEADER=Authorization
COPAW_API_KEY_PREFIX=Bearer

# 请求超时时间（毫秒）
COPAW_TIMEOUT_MS=30000

# CoPaw 工作区根目录（用于将生成文件映射为可访问 URL）
# Windows 例子：C:/Users/Administrator/.copaw/workspaces
COPAW_WORKSPACE_ROOT=
# 文件名搜索深度/规模限制（可选）
COPAW_FILE_SEARCH_MAX_DEPTH=8
COPAW_FILE_SEARCH_MAX_ENTRIES=20000

# 本地数据库
DB_PATH=./data/mvp.db

# 管理排查接口（可选）
# GET /api/admin/sessions 需要在请求头携带 x-admin-token
ADMIN_TOKEN=
